{
  "name": "arvea-ui-kit",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/core --workspace=packages/components",
    "dev": "npm run dev --workspace=apps/storybook",
    "dev:next": "concurrently -n components,next-demo -c cyan,green \"npm run dev -w packages/components\" \"npm run dev -w apps/next-demo\"",
    "storybook": "npm run storybook --workspace=apps/storybook",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-lit": "^2.2.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
