{
  "name": "@arvea-ui/kit",
  "version": "0.4.3",
  "description": "Arvea UI Kit — framework-agnostic Web Components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./tokens.css": "./tokens.css"
  },
  "files": [
    "dist",
    "tokens.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "peerDependencies": {
    "lit": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/web-components-vite": "^10.3.5",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lit": "^3.0.0",
    "react": "^19.2.5",
    "ts-jest": "^29.4.9",
    "tsup": "^8.0.0"
  },
  "license": "MIT",
  "keywords": [
    "web-components",
    "lit",
    "ui-kit",
    "design-system",
    "arvea"
  ],
  "dependencies": {
    "@lit/react": "^1.0.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
